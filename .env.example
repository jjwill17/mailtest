# Copy to `.env` and fill in. The .env file is gitignored.
#
# These are the only two env vars you NEED for the public demo posture.
# Everything else in docker-compose.yml has sensible defaults.

# Set to "true" to enable the demo guard rails (destructive endpoints
# require X-Admin-Key, PII gets redacted in the UI/exports).
DEMO_MODE=false

# Long random string. Required when DEMO_MODE=true. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# Optional overrides (uncomment + change to deviate from docker-compose defaults).
# DEMO_INBOUND_ADDRESS=demo@example.com
# OWNER_NAME=Your Name
# OWNER_URL=https://github.com/your-handle
# INGEST_MIN_INTERVAL_SECONDS=60
# INGEST_DAILY_CAP=20
# BRIDGE_RATE_CAP=30
# BRIDGE_RATE_WINDOW_SECONDS=60
# MAX_INGEST_BYTES=1048576
