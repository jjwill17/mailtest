# Copy to /etc/mailtest-tunnel.env, chown root:root, chmod 600.
# The systemd unit reads these as environment variables at ExecStart time.

# SSH target: dedicated tunnel user + VPS hostname or IP.
SSH_TARGET=tunnel@mailtest.justfortesting.xyz

# Absolute path to the dedicated SSH private key on the home machine.
# Must be readable by the User= in mailtest-tunnel.service.
SSH_KEY=/home/justin/.ssh/mailtest_tunnel_ed25519

# VPS-side port that Caddy reverse-proxies to (see VPS Caddyfile).
# autossh will bind this on the VPS loopback interface.
REMOTE_BIND=18080

# Home-side port the FastAPI container publishes on (see docker-compose.yml).
LOCAL_PORT=8080
